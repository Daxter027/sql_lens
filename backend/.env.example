# ─────────────────────────────────────────────────────────────────────────────
# Storage Optimization Tool — backend environment variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` (same folder) and fill in the values you want to
# override. config.py loads `.env` automatically at startup.
#
#   cp .env.example .env        # (PowerShell: Copy-Item .env.example .env)
#
# Rules:
#   - Lines are KEY=VALUE. Blank lines and lines starting with '#' are ignored.
#   - A REAL OS environment variable (setx / $env: / export) ALWAYS wins over a
#     value set here.
#   - Anything NOT set here falls back to the default shown in config.py.
#   - Restart uvicorn after editing — values are read once at startup.
#
# SECURITY: `.env` will contain your secret API key. Do NOT commit it. Keep only
# `.env.example` (this file, no secrets) in version control.
# ─────────────────────────────────────────────────────────────────────────────


# ── AI Storage & Redundancy Analysis (Anthropic Claude API) ──────────────────

# REQUIRED for the AI feature. Your Anthropic API key (https://console.anthropic.com).
# Without it the feature returns an "API key problem" error.
ANTHROPIC_API_KEY=

# Default model for the analysis. Override per-run from the UI dropdown too.
#   claude-sonnet-4-6  (default, balanced)
#   claude-haiku-4-5   (fast / cheapest)
#   claude-opus-4-8    (max quality)
ANTHROPIC_MODEL=claude-sonnet-4-6

# API endpoint and version header — rarely need changing.
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_VERSION=2023-06-01

# HTTP timeout (seconds) for the Claude call.
ANTHROPIC_TIMEOUT_SECONDS=120

# Max output tokens for the report. If a run ends mid-sentence, raise this — the
# model is being clipped at this cap (the UI flags it when that happens).
ANTHROPIC_MAX_TOKENS=4000

# Sampling temperature (0.0–1.0). Low = consistent, factual.
ANTHROPIC_TEMPERATURE=0.25

# Max table rows sent to the model (the top-N largest tables by storage).
STORAGE_REDUNDANCY_ROW_CAP=200
